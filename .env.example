# =============================================================================
# Side Quest — environment variables
# Copy to .env (gitignored):  cp .env.example .env
#
# AGENT MINIMUM (remote push + app against live Supabase):
#   EXPO_PUBLIC_SUPABASE_URL
#   EXPO_PUBLIC_SUPABASE_ANON_KEY
#
# ALSO NEED (not in this file):
#   - supabase login (CLI session on your machine)
#   - Supabase Dashboard: Auth providers + redirect URLs (see docs/PHASE3_AUTH.md)
#
# EXPO_PUBLIC_ whitelist (safe to bundle in client):
#   EXPO_PUBLIC_SUPABASE_URL, EXPO_PUBLIC_SUPABASE_ANON_KEY, EXPO_PUBLIC_APP_SCHEME,
#   EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID, EXPO_PUBLIC_PRIVACY_POLICY_URL, EXPO_PUBLIC_TERMS_URL
# Dev-only / secrets: use DEV_* or server-only names (see scripts/check-expo-public-safety.sh)
#
# Full checklist: docs/FINAL_CHECKLIST.md
# =============================================================================

# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Twilio → Supabase Dashboard → Auth → Phone only (NOT mobile .env)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_MESSAGING_SERVICE_SID=MG...   # Console → Messaging → Services → your service → Properties

# Apple → generate Client Secret for Supabase Dashboard (NOT mobile .env / never EXPO_PUBLIC_)
# APPLE_TEAM_ID=<10-char Team ID>
# APPLE_AUTH_KEY_ID=<10-char Key ID>
# APPLE_SERVICES_CLIENT_ID=au.enginelabs.sidequest.web
# APPLE_CLIENT_SECRET=eyJ...   # JWT from npm run generate:apple-secret → Supabase Apple Secret Key

# OAuth (optional — Google sign-in; also configure in Supabase Dashboard)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Google Client Secret → Supabase Dashboard → Auth → Google ONLY (never EXPO_PUBLIC_ or .env commit)
EXPO_PUBLIC_APP_SCHEME=sidequest

# Google Maps — see docs/GOOGLE_MAPS_SETUP.md
# Production search: Supabase Edge Function `places-search` + secret GOOGLE_MAPS_PLACES_API_KEY
#   supabase secrets set GOOGLE_MAPS_PLACES_API_KEY=... --project-ref <ref>
GOOGLE_MAPS_PLACES_API_KEY=
# Dev fallback: direct Places API in __DEV__ (injected via app.config.ts extra — not EXPO_PUBLIC_)
DEV_PLACES_API_KEY=
# DEV_PLACES_FALLBACK=false
# Native map SDK keys (dev client / EAS builds — baked in at prebuild, not in JS bundle)
GOOGLE_MAPS_IOS_API_KEY=
GOOGLE_MAPS_ANDROID_API_KEY=

# Legal (optional for dev E2E; required before store submission)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://enginelabs-au.github.io/sidequest/legal/privacy.html
EXPO_PUBLIC_TERMS_URL=https://enginelabs-au.github.io/sidequest/legal/terms.html

# Simulator dev bypass (TEMPORARY — omit DEV_AUTH_* in production/EAS builds)
# Injected via app.config.ts extra — never EXPO_PUBLIC_
# Also skips the 1 km check-in gate while testing (or set DEV_CHECKIN_BYPASS=true alone)
DEV_AUTH_BYPASS=true
# DEV_CHECKIN_BYPASS=true
# DEV_AUTH_EMAIL=dev@example.com
# DEV_AUTH_PASSWORD=your-test-password

# Future / server-only — never bundle in the mobile client
# SUPABASE_SERVICE_ROLE_KEY=
# OPENAI_API_KEY=
