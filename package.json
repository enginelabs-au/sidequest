{
  "name": "sidequest",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@supabase/supabase-js": "^2.110.1",
    "expo": "~57.0.4",
    "expo-apple-authentication": "^57.0.0",
    "expo-auth-session": "^57.0.2",
    "expo-constants": "~57.0.3",
    "expo-crypto": "^57.0.0",
    "expo-font": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-location": "^57.0.2",
    "expo-router": "~57.0.4",
    "expo-secure-store": "^57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "db:types": "supabase gen types typescript --linked > types/database.generated.ts",
    "verify:env": "bash scripts/verify-env.sh",
    "verify:phone-auth": "bash scripts/verify-phone-auth.sh",
    "verify:connections": "bash scripts/verify-connections.sh",
    "test:oauth": "node scripts/test-oauth-providers.mjs",
    "setup:google-native": "bash scripts/setup-google-native-oauth.sh",
    "setup:phone-auth": "bash scripts/patch-supabase-phone-auth.sh",
    "print:supabase-auth": "bash scripts/print-supabase-native-auth.sh",
    "generate:apple-secret": "node scripts/generate-apple-secret.mjs",
    "generate:icons": "python3 scripts/generate-app-icons.py"
  },
  "private": true
}
